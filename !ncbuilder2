  on('chat:message', (msg) => {
    if (msg.type !== 'api' || !msg.content.startsWith(CMD)) return;
    initState();
    const parsed = parseAction(msg.content);
    const action = parsed.action;
    const args = parsed.args;

    if (action === 'start') {
      const token = getSelectedToken(msg);
      if (!token) return error(msg.playerid, 'Select exactly one token.');
      return renderStartOrHub(msg, token);
    }

    if (action === 'hub') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderHub(msg.playerid, tokenId, session);
    }

    if (action === 'reset') {
      const tokenId = args[0];
      clearSession(tokenId);
      return whisperBoth(msg.playerid, H.box(H.title('Reset') + H.row('Character creation session cleared.')));
    }

    if (action === 'name') {
      const tokenId = args[0];
      const chosenName = args.slice(1).join('|');
      const token = getObj('graphic', tokenId);
      if (!token) return error(msg.playerid, 'Token not found.');
      const character = characterFromToken(token, chosenName);
      const session = {
        playerId: msg.playerid, tokenId, characterId: character.id,
        name: character.get('name'), rerollsUsed: 0, rolledSet: [], remainingRolls: [], assignedScores: { strength: null, intelligence: null, wisdom: null, dexterity: null, constitution: null, charisma: null }, baseStats: null, finalStats: null,
        race: null, className: null, alignment: null, level: 1, xp: 0, exceptionalStrength: '',
        appliedRaceAdjustments: null,
        gender: 'male', age: '', height: '', weight: '', eyes: '', hair: '',
        movement: 12, movementHeavy: 9, movementLoad: 6, movementMax: 15,
        startingWalletGp: 0, startingMoneyFormula: '', startingMoneyRolls: [], walletGp: 0, coins: { gp: 0, sp: 0, ep: 0, cp: 0, pp: 0 }, purchases: [], cart: [],
        hpTotal: 1, hpLog: [], languages: ['Common']
      };
      setSession(tokenId, session);
      liveWriteCoins(session);
      liveWriteRaceClassLevelAlignment(session);
      liveWriteHpAndMovement(session);
      liveWriteDetails(session);
      return renderHub(msg.playerid, tokenId, session);
    }

    if (action === 'manualscores') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      const vals = args.slice(1, 7).map(v => parseInt(v, 10));
      if (vals.length !== 6 || vals.some(v => isNaN(v))) return error(msg.playerid, 'Enter all six ability scores.');
      if (vals.some(v => v < 3 || v > 18)) return error(msg.playerid, 'Each score must be between 3 and 18.');
      session.rolledSet = vals.slice();
      session.remainingRolls = vals.slice().sort((a,b)=>b-a);
      session.assignedScores = { strength: null, intelligence: null, wisdom: null, dexterity: null, constitution: null, charisma: null };
      session.baseStats = null;
      session.finalStats = null;
      syncLanguages(session);
      setSession(tokenId, session);
      return renderAssignMenu(msg.playerid, tokenId, session);
    }

    if (action === 'rollabilities') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (session.rolledSet && session.rolledSet.length) {
        return renderRolledSet(msg.playerid, tokenId, session);
      }
      session.rolledSet = rollAbilitySet();
      session.remainingRolls = clone(session.rolledSet);
      session.assignedScores = { strength: null, intelligence: null, wisdom: null, dexterity: null, constitution: null, charisma: null };
      session.baseStats = null;
      session.finalStats = null;
      setSession(tokenId, session);
      return renderRolledSet(msg.playerid, tokenId, session);
    }

    if (action === 'reroll') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (session.rerollsUsed >= 3) return error(msg.playerid, 'No rerolls remaining.');
      session.rerollsUsed += 1;
      session.rolledSet = rollAbilitySet();
      session.remainingRolls = clone(session.rolledSet);
      session.assignedScores = { strength: null, intelligence: null, wisdom: null, dexterity: null, constitution: null, charisma: null };
      session.baseStats = null;
      session.finalStats = null;
      setSession(tokenId, session);
      return renderRolledSet(msg.playerid, tokenId, session);
    }

    if (action === 'assignmenu') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderAssignMenu(msg.playerid, tokenId, session);
    }

    if (action === 'assignability') {
      const tokenId = args[0];
      const ability = args[1];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (ABILITIES.indexOf(ability) === -1) return error(msg.playerid, 'Invalid ability.');
      return renderAssignPicker(msg.playerid, tokenId, session, ability);
    }

    if (action === 'assignpick') {
      const tokenId = args[0];
      const ability = args[1];
      const value = parseInt(args[2], 10);
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (ABILITIES.indexOf(ability) === -1) return error(msg.playerid, 'Invalid ability.');

      const choices = [];
      if (typeof session.assignedScores[ability] === 'number') {
        choices.push(session.assignedScores[ability]);
      }
      (session.remainingRolls || []).forEach(v => {
        choices.push(v);
      });
      if (choices.indexOf(value) === -1) return error(msg.playerid, 'That value is not available for this assignment.');

      setAssignedValue(session, ability, value);
      syncExceptionalStrength(session);
      if (session.baseStats) {
        if (session.className) applyDefaultLevelDerived(session);
        liveWriteAllAssignedStats(session);
        liveWriteRaceClassLevelAlignment(session);
        liveWriteHpAndMovement(session);
      }
      setSession(tokenId, session);
      return renderAssignMenu(msg.playerid, tokenId, session);
    }

    if (action === 'racemenu') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderRaceMenu(msg.playerid, tokenId, session);
    }

    if (action === 'race') {
      const tokenId = args[0];
      const race = args.slice(1).join('|');
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (!session.baseStats) return error(msg.playerid, 'Assign abilities first.');
      if (!RACE_DATA[race]) return error(msg.playerid, 'Invalid race.');
      const adjusted = applyRacialAdjustments(session.baseStats, race);
      if (!raceMeetsLimits(race, adjusted)) return error(msg.playerid, 'That race is blocked by current ability minimums/maximums.');
      session.race = race;
      session.finalStats = adjusted;
      session.bonusLanguages = [];
      syncLanguages(session);
      if (session.className) applyDefaultLevelDerived(session);
      liveWriteAllAssignedStats(session);
      liveWriteRaceClassLevelAlignment(session);
      liveWriteHpAndMovement(session);
      setSession(tokenId, session);
      return renderHub(msg.playerid, tokenId, session);
    }

    if (action === 'classmenu') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderClassMenu(msg.playerid, tokenId, session);
    }

    if (action === 'class') {
      const tokenId = args[0];
      const className = args.slice(1).join('|');
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (!session.race || !session.finalStats) return error(msg.playerid, 'Choose race and assign abilities first.');
      if (!session.alignment) return error(msg.playerid, 'Choose alignment first.');
      const legal = legalClassesForRaceStatsAlignment(session.race, session.finalStats, session.alignment);
      if (legal.indexOf(className) === -1) return error(msg.playerid, 'Illegal class for current race, stats, or alignment.');
      session.className = className;
      syncExceptionalStrength(session);
      applyDefaultLevelDerived(session);
      liveWriteAllAssignedStats(session);
      liveWriteRaceClassLevelAlignment(session);
      liveWriteHpAndMovement(session);
      setSession(tokenId, session);
      return renderHub(msg.playerid, tokenId, session);
    }

    if (action === 'alignmentmenu') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderAlignmentMenu(msg.playerid, tokenId, session);
    }

    if (action === 'alignment') {
      const tokenId = args[0];
      const alignment = args.slice(1).join('|');
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (!session.race || !session.finalStats) return error(msg.playerid, 'Choose race and assign abilities first.');

      if (session.className) {
        const legal = legalAlignmentsForClass(session.className);
        if (legal.indexOf(alignment) === -1) return error(msg.playerid, 'Illegal alignment for class.');
      } else {
        if (ALIGNMENTS.indexOf(alignment) === -1) return error(msg.playerid, 'Invalid alignment.');
      }

      session.alignment = alignment;
      liveWriteRaceClassLevelAlignment(session);
      setSession(tokenId, session);
      return renderHub(msg.playerid, tokenId, session);
    }

    if (action === 'levelmenu') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderLevelMenu(msg.playerid, tokenId, session);
    }

    if (action === 'level') {
      const tokenId = args[0];
      const chosen = clamp(parseInt(args[1], 10) || 1, 1, 99);
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (!session.className) return error(msg.playerid, 'Choose class first.');

      session.level = chosen;
      session.xp = xpForLevel(session.className, chosen);

      const money = moneyForClass(session.className);
      session.walletGp = money.totalGp;
      session.startingWalletGp = money.totalGp;
      session.coins = goldToCoins(money.totalGp);
      session.startingMoneyFormula = money.formula;
      session.startingMoneyRolls = money.rolls;

      const conMod = constitutionHpMod((session.finalStats && session.finalStats.constitution) || 10);
      const hp = hpForLevel(session.className, session.level, conMod);
      session.hpTotal = hp.total;
      session.hpLog = hp.log;

      liveWriteRaceClassLevelAlignment(session);
      liveWriteHpAndMovement(session);
      liveWriteCoins(session);
      setSession(tokenId, session);
      return renderHub(msg.playerid, tokenId, session);
    }

    if (action === 'languagemenu') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderLanguageMenu(msg.playerid, tokenId, session);
    }

    if (action === 'languagetoggle') {
      const tokenId = args[0];
      const lang = args.slice(1).join('|');
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (!session.race || !session.finalStats) return error(msg.playerid, 'Choose race and assign abilities first.');
      syncLanguages(session);
      const base = RACE_DATA[session.race] ? clone(RACE_DATA[session.race].languages || []) : ['Common'];
      if (base.indexOf(lang) !== -1) return renderLanguageMenu(msg.playerid, tokenId, session);
      session.bonusLanguages = uniqueStrings(session.bonusLanguages || []);
      const idxLang = session.bonusLanguages.indexOf(lang);
      if (idxLang !== -1) {
        session.bonusLanguages.splice(idxLang, 1);
      } else {
        const maxPicks = intBonusLanguageCount(session.finalStats ? session.finalStats.intelligence : 0);
        if (session.bonusLanguages.length >= maxPicks) return error(msg.playerid, 'No bonus language picks remaining.');
        if (BONUS_LANGUAGE_POOL.indexOf(lang) === -1) return error(msg.playerid, 'Invalid language.');
        session.bonusLanguages.push(lang);
      }
      syncLanguages(session);
      liveWriteRaceClassLevelAlignment(session);
      setSession(tokenId, session);
      return renderLanguageMenu(msg.playerid, tokenId, session);
    }

    if (action === 'manualassign') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      const vals = args.slice(1, 7).map(v => parseInt(v, 10));
      if (vals.length !== 6 || vals.some(v => isNaN(v))) return error(msg.playerid, 'Enter all six ability scores.');
      if (vals.some(v => v < 3 || v > 18)) return error(msg.playerid, 'Each score must be between 3 and 18.');
      session.rolledSet = vals.slice();
      session.assignedScores = {
        strength: vals[0],
        intelligence: vals[1],
        wisdom: vals[2],
        dexterity: vals[3],
        constitution: vals[4],
        charisma: vals[5]
      };
      session.remainingRolls = [];
      session.baseStats = clone(session.assignedScores);
      session.finalStats = clone(session.baseStats);
      if (session.race) session.finalStats = applyRacialAdjustments(session.baseStats, session.race);
      syncExceptionalStrength(session);
      syncLanguages(session);
      if (session.className) applyDefaultLevelDerived(session);
      liveWriteAllAssignedStats(session);
      liveWriteRaceClassLevelAlignment(session);
      liveWriteHpAndMovement(session);
      setSession(tokenId, session);
      return renderAssignMenu(msg.playerid, tokenId, session);
    }

    if (action === 'dropability') {
      const tokenId = args[0];
      const ability = args[1];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (ABILITIES.indexOf(ability) === -1) return error(msg.playerid, 'Invalid ability.');
      clearAssignedValue(session, ability);
      liveWriteAllAssignedStats(session);
      liveWriteRaceClassLevelAlignment(session);
      liveWriteHpAndMovement(session);
      setSession(tokenId, session);
      return renderAssignMenu(msg.playerid, tokenId, session);
    }

    if (action === 'detailsmenu') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderDetailsMenu(msg.playerid, tokenId, session);
    }

    if (action === 'rolldetails') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      const hw = rollHeightWeight(session.race || 'Human', session.gender || 'male');
      session.age = rollAge(session.race || 'Human');
      session.height = inchesToFeetString(hw.inches);
      session.weight = hw.weight;
      session.eyes = rollEyes();
      session.hair = rollHair();
      liveWriteDetails(session);
      setSession(tokenId, session);
      return renderDetailsMenu(msg.playerid, tokenId, session);
    }

    if (action === 'setdetails') {
      const tokenId = args[0];
      const gender = args[1];
      const age = args[2];
      const height = args[3];
      const weight = args[4];
      const eyes = args[5];
      const hair = args[6];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      session.gender = gender;
      session.age = age;
      session.height = height;
      session.weight = weight;
      session.eyes = eyes;
      session.hair = hair;
      liveWriteDetails(session);
      setSession(tokenId, session);
      return renderDetailsMenu(msg.playerid, tokenId, session);
    }

    if (action === 'refreshderived') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (session.className) applyDefaultLevelDerived(session);
      forceDerivedRefresh(session);
      setSession(tokenId, session);
      return renderHub(msg.playerid, tokenId, session);
    }

    if (action === 'viewcart') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderCart(msg.playerid, tokenId, session);
    }

    if (action === 'removecart') {
      const tokenId = args[0];
      const idx = parseInt(args[1], 10);
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      const result = removeCartIndex(session, idx);
      if (!result.ok) return error(msg.playerid, result.msg);
      liveWriteCoins(session);
      setSession(tokenId, session);
      return renderCart(msg.playerid, tokenId, session);
    }

    if (action === 'checkout') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      const result = checkoutCart(session);
      if (!result.ok) return error(msg.playerid, result.msg);
      setSession(tokenId, session);
      return renderEquipmentCategories(msg.playerid, tokenId, session);
    }

    if (action === 'equipweapons') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderWeaponSyncMenu(msg.playerid, tokenId, session);
    }

    if (action === 'equipweaponitem') {
      const tokenId = args[0];
      const idx = parseInt(args[1], 10);
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      const ok = syncOneWeaponFromPurchase(session, idx);
      if (!ok) return error(msg.playerid, 'Weapon could not be equipped.');
      setSession(tokenId, session);
      return renderWeaponSyncMenu(msg.playerid, tokenId, session);
    }

    if (action === 'equiparmor') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderArmorSyncMenu(msg.playerid, tokenId, session);
    }

    if (action === 'equiparmoritem') {
      const tokenId = args[0];
      const idx = parseInt(args[1], 10);
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      const ok = syncOneArmorFromPurchase(session, idx);
      if (!ok) return error(msg.playerid, 'Armor could not be equipped.');
      setSession(tokenId, session);
      return renderArmorSyncMenu(msg.playerid, tokenId, session);
    }

    if (action === 'equipmenu') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderEquipmentCategories(msg.playerid, tokenId, session);
    }

    if (action === 'equipcat') {
      const tokenId = args[0];
      const category = args[1];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      return renderEquipmentList(msg.playerid, tokenId, session, category);
    }

    if (action === 'addtocart') {
      const tokenId = args[0];
      const itemKey = args[1];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      const result = addToCart(session, itemKey);
      if (!result.ok) return error(msg.playerid, result.msg);
      liveWriteCoins(session);
      setSession(tokenId, session);
      return renderEquipmentCategories(msg.playerid, tokenId, session);
    }

    if (action === 'finish') {
      const tokenId = args[0];
      const session = getSession(tokenId);
      if (!session) return error(msg.playerid, 'No active session.');
      if (!session.baseStats || !session.race || !session.className || !session.alignment) {
        return error(msg.playerid, 'Complete abilities, race, class, and alignment first.');
      }
      if (!session.age) {
        const hw = rollHeightWeight(session.race || 'Human', session.gender || 'male');
        session.age = rollAge(session.race || 'Human');
        session.height = inchesToFeetString(hw.inches);
        session.weight = hw.weight;
        session.eyes = rollEyes();
        session.hair = rollHair();
        liveWriteDetails(session);
      }
      setSession(tokenId, session);
      sendSummary(msg.playerid, session);
      clearSession(tokenId);
      return;
    }

    if (action === 'raceinfo') {
      const tokenId = args[0];
      const race = args.slice(1).join('|');
      return renderRaceInfo(msg.playerid, tokenId, race);
    }

    if (action === 'racereq') {
      const tokenId = args[0];
      const race = args.slice(1).join('|');
      return renderRaceRequirements(msg.playerid, tokenId, race);
    }

    if (action === 'classinfo') {
      const tokenId = args[0];
      const className = args.slice(1).join('|');
      return renderClassInfo(msg.playerid, tokenId, className);
    }

    if (action === 'requirements') {
      const tokenId = args[0];
      const className = args.slice(1).join('|');
      return renderRequirements(msg.playerid, tokenId, className);
    }

    if (action === 'abilitynotes') {
      const tokenId = args[0];
      const rows = ABILITIES.map(a => H.row(`<b>${ABILITY_LABELS[a]}</b>: ${H.esc(summarizeAbilityInfo(a))}`)).join('');
      whisperBoth(msg.playerid, H.box(H.title('Ability Notes') + rows + H.row(H.btn('Back', `${CMD} --hub|${tokenId}`))));
      return;
    }

    if (action === 'help') {
      return whisperBoth(msg.playerid, H.box(
        H.title('NewCharacter1E Help') +
        H.row('Select one token and run !newcharacter') +
        H.row('Use the main menu buttons to complete each section in any order.')
      ));
    }
  });

  on('ready', () => {
    initState();
    log(`${SCRIPT} v${VERSION} ready`);
  });

  return {};
})();
