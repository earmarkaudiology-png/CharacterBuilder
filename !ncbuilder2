      const setup = armorFieldSetup(item.name);
      if (!setup) return;
      if (setup.slot === 'shield' && !armorShield) {
        armorShield = item.name;
        armorShieldAC = setup.ac;
      } else if (setup.slot === 'helmet' && !armorHelmet) {
        armorHelmet = item.name;
        armorHelmetAC = setup.ac;
      } else if (setup.slot === 'armor' && !armorType) {
        armorType = item.name;
        armorTypeAC = setup.ac;
      }
    });

