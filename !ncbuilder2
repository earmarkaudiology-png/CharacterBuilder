  const getCurrentIntelligenceSpellData = (intel) => {
    let know = 0, minS = 0, maxS = 0;
    if (intel === 9) { know = 35; minS = 4; maxS = 6; }
    else if (intel >= 10 && intel <= 12) { know = 45; minS = 5; maxS = 7; }
    else if (intel >= 13 && intel <= 14) { know = 55; minS = 6; maxS = 9; }
    else if (intel >= 15 && intel <= 16) { know = 65; minS = 7; maxS = 11; }
    else if (intel === 17) { know = 75; minS = 8; maxS = 14; }
    else if (intel >= 18) { know = 85; minS = 9; maxS = 18; }
    return { know, minS, maxS };
  };

  const getCurrentCharismaData = (cha) => {
    let maxHench = 4, loyalty = '0', reaction = '0';
    if (cha <= 3) { maxHench = 1; loyalty = '-30'; reaction = '-25'; }
    else if (cha === 4) { maxHench = 1; loyalty = '-25'; reaction = '-20'; }
    else if (cha === 5) { maxHench = 2; loyalty = '-20'; reaction = '-15'; }
    else if (cha === 6) { maxHench = 2; loyalty = '-15'; reaction = '-10'; }
    else if (cha === 7) { maxHench = 3; loyalty = '-10'; reaction = '-05'; }
    else if (cha === 8) { maxHench = 3; loyalty = '-05'; reaction = '0'; }
    else if (cha >= 9 && cha <= 11) { maxHench = 4; loyalty = '0'; reaction = '0'; }
    else if (cha === 12) { maxHench = 5; loyalty = '0'; reaction = '0'; }
    else if (cha === 13) { maxHench = 5; loyalty = '0'; reaction = '+05'; }
    else if (cha === 14) { maxHench = 6; loyalty = '+05'; reaction = '+10'; }
    else if (cha === 15) { maxHench = 7; loyalty = '+15'; reaction = '+15'; }
    else if (cha === 16) { maxHench = 8; loyalty = '+20'; reaction = '+25'; }
    else if (cha === 17) { maxHench = 10; loyalty = '+30'; reaction = '+30'; }
    else if (cha >= 18) { maxHench = 15; loyalty = '+40'; reaction = '+35'; }
    return { maxHench, loyalty, reaction };
  };

  const liveWriteAbilityAndDerived = (characterId, ability, value) => {
    setAttr(characterId, ATTR[ability], value);
    if (ability === 'intelligence') {
      const d = getCurrentIntelligenceSpellData(value);
      setAttr(characterId, ATTR.knowspell, d.know);
      setAttr(characterId, ATTR.minspells, d.minS);
      setAttr(characterId, ATTR.maxspells, d.maxS);
    }
    if (ability === 'charisma') {
      const d = getCurrentCharismaData(value);
      setAttr(characterId, ATTR.maximumhenchmen, d.maxHench);
      setAttr(characterId, ATTR.loyaltybonus, d.loyalty);
      setAttr(characterId, ATTR.reactionbonus, d.reaction);
