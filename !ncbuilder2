  const findAttr = (characterId, name) => findObjs({ type: 'attribute', characterid: characterId, name })[0];
  const sanitizeAttrValue = (value) => {
    if (value === null || typeof value === 'undefined') return '';
    if (typeof value === 'number' && !isFinite(value)) return '';
    if (typeof value === 'string' && value.trim().toLowerCase() === 'nan') return '';
    return value;
  };

  const setAttr = (characterId, name, current, max) => {
    let attr = findAttr(characterId, name);
    if (!attr) attr = createObj('attribute', { characterid: characterId, name, current: '' });
    attr.set('current', sanitizeAttrValue(current));
    if (typeof max !== 'undefined') attr.set('max', sanitizeAttrValue(max));
    return attr;
  };

  const clearRepeatingSection = (characterId, section) => {
    findObjs({ type: 'attribute', characterid: characterId }).forEach(attr => {
      const n = attr.get('name');
      if (n.indexOf(section + '_') === 0) attr.remove();
    });
  };

  const getEquipmentRows = (characterId) => {
    const attrs = findObjs({ type: 'attribute', characterid: characterId });
    const rows = {};
    attrs.forEach(attr => {
      const n = attr.get('name');
      const m = n.match(/^repeating_equipment_([^_]+)_(.+)$/);
      if (!m) return;
      const rowId = m[1];
      const field = m[2];
      rows[rowId] = rows[rowId] || {};
      rows[rowId][field] = attr.get('current');
      rows[rowId]._rowId = rowId;
    });
    return Object.values(rows);
  };

