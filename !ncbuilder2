    if (!session || !session.characterId || !item) return false;
    const setup = armorFieldSetup(item.name);
    if (!setup) return false;
    if (setup.slot === 'shield') {
      setAttr(session.characterId, ATTR.armorShield, item.name);
      setAttr(session.characterId, ATTR.armorShieldAC, setup.ac);
    } else if (setup.slot === 'helmet') {
      setAttr(session.characterId, ATTR.armorHelmet, item.name);
      setAttr(session.characterId, ATTR.armorHelmetAC, setup.ac);
    } else if (setup.slot === 'armor') {
      setAttr(session.characterId, ATTR.armorType, item.name);
      setAttr(session.characterId, ATTR.armorTypeAC, setup.ac);
    }
    return true;
