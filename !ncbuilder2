  const error = (playerId, msg) => whisperBoth(playerId, H.box(H.title('Error') + H.row(msg)));
  const addToCart = (session, key) => {
    session.cart = session.cart || [];
    session.purchases = session.purchases || [];
    const item = EQUIPMENT.find(i => i.key === key);
    if (!item) return { ok: false, msg: 'Item not found.' };
    const itemName = safeItemName(item);
    if (item.category === 'armor' && session.className && !canClassUseItem(session.className, itemName)) {
      return { ok: false, msg: `${session.className} cannot use that armor.` };
    }
    if (itemIsWeapon(item) && session.className && !weaponAllowedForClass(session.className, itemName)) {
      return { ok: false, msg: `${session.className} cannot use that weapon.` };
    }
    const priceGp = itemPriceInGp(item);
    if (session.walletGp + 0.0001 < priceGp) return { ok: false, msg: 'Not enough gold.' };
    session.walletGp = Math.round((session.walletGp - priceGp) * 100) / 100;
    const normalized = Object.assign({}, item, {
      name: itemName,
      priceGp,
      price: String(item.price || (priceGp ? `${priceGp} gp` : '')),
      quantity: 1,
      weight: baseItemWeight(Object.assign({}, item, { name: itemName })),
      type: 'gear',
