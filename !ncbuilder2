    if (!session.cart.length) {
      return { ok: false, msg: 'Cart is empty.' };
    }

    const lines = session.cart.map(i => Object.assign({}, i));
    session.cart = [];

    for (let i = 0; i < lines.length; i++) {
      const item = Object.assign({}, lines[i], {
        quantity: clamp(parseInt(lines[i].quantity, 10) || 1, 1, 9999),
        type: 'gear'
      });

      session.purchases.push(item);
      liveAddPurchasedItem(session, item);
    }

    liveWriteCoins(session);
    return { ok: true, count: lines.length };
