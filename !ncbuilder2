    const cart = session.cart || [];
    if (idx < 0 || idx >= cart.length) return { ok: false, msg: 'Cart item not found.' };
    const item = cart[idx];
    const qty = Number(item.quantity || 1) || 1;
    session.walletGp = Math.round((session.walletGp + (item.priceGp || 0) * qty) * 100) / 100;
    cart.splice(idx, 1);
