    if (!session.race) {
      session.finalStats = JSON.parse(JSON.stringify(session.baseStats));
      session.appliedRaceAdjustments = null;
      return session.finalStats;
    }
    const adjusted = applyRacialAdjustments(session.baseStats, session.race);
    session.finalStats = adjusted;
    session.appliedRaceAdjustments = session.race;
    return adjusted;
  };

